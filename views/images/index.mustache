<!doctype html>
<html lang="en">
<head>
    {{> head }}
    <style>
        .drop-zone {
            border: 2px dashed #6c757d;
            border-radius: 8px;
            padding: 40px;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.2s, background 0.2s;
        }
        .drop-zone.drag-over {
            border-color: #007bff;
            background: rgba(0,123,255,0.05);
        }
        .gallery-img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            cursor: pointer;
            border-radius: 4px 4px 0 0;
        }
        .lightbox-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.88);
            z-index: 9999;
            justify-content: center;
            align-items: center;
        }
        .lightbox-overlay.active {
            display: flex;
        }
        .lightbox-img {
            max-width: 90vw;
            max-height: 85vh;
            border-radius: 4px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.6);
        }
        .lightbox-close {
            position: absolute;
            top: 20px;
            right: 28px;
            font-size: 2rem;
            color: #fff;
            cursor: pointer;
            line-height: 1;
        }
        .lightbox-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            font-size: 2.5rem;
            color: rgba(255,255,255,0.8);
            cursor: pointer;
            user-select: none;
            padding: 8px 16px;
            transition: color 0.15s;
            z-index: 1;
        }
        .lightbox-arrow:hover { color: #fff; }
        .lightbox-arrow.prev { left: 16px; }
        .lightbox-arrow.next { right: 16px; }
        .lightbox-counter {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            color: rgba(255,255,255,0.7);
            font-size: 0.85rem;
        }
        .lightbox-actions {
            position: absolute;
            bottom: 24px;
            display: flex;
            gap: 12px;
        }
        .fname {
            font-size: 0.75rem;
            word-break: break-all;
        }
        #uploadProgress {
            display: none;
        }
    </style>
</head>
<body class="vertical dark">
<div class="wrapper">
    {{> include}}
    <nav class="topnav navbar navbar-light">
        {{> navbar }}
    </nav>
    <main role="main" class="main-content">
        <div class="container-fluid">
            <div class="row justify-content-center">
                <div class="col-12">

                    <div class="d-flex align-items-center mb-3">
                        <h6 class="mb-0 mr-3">Images</h6>
                        <span class="badge badge-secondary">{{imageCount}} files</span>
                    </div>

                    <!-- Upload area -->
                    <div class="card shadow mb-4">
                        <div class="card-body p-3">
                            <div id="dropZone" class="drop-zone">
                                <i class="fe fe-upload-cloud fe-24 text-muted mb-2 d-block"></i>
                                <p class="mb-1 text-muted">Drag &amp; drop images here, or <strong>click to browse</strong></p>
                                <p class="small text-muted mb-0">PNG, JPG, GIF, WEBP supported</p>
                                <input id="fileInput" type="file" accept="image/*" multiple class="d-none">
                            </div>
                            <div id="uploadProgress" class="mt-3">
                                <div class="progress">
                                    <div id="progressBar" class="progress-bar progress-bar-striped progress-bar-animated" style="width: 0%"></div>
                                </div>
                                <small id="uploadStatus" class="text-muted"></small>
                            </div>
                        </div>
                    </div>

                    <!-- Gallery grid -->
                    <div class="row" id="gallery">
                        {{#images}}
                        <div class="col-6 col-md-3 col-lg-2 mb-4 gallery-item" data-filename="{{filename}}">
                            <div class="card shadow h-100">
                                <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
                                     data-src="/img/{{filename}}" alt="{{filename}}"
                                     class="gallery-img lazy">
                                <div class="card-body p-2">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-muted">{{relativeCreatedAt}}</small>
                                        <div class="btn-group">
                                            <button type="button" class="btn btn-sm btn-outline-secondary btnCopy"
                                                    data-filename="{{filename}}" title="Copy URL">
                                                <i class="fe fe-copy fe-12"></i>
                                            </button>
                                            <button type="button" class="btn btn-sm btn-outline-danger btnDelete"
                                                    data-filename="{{filename}}" title="Delete">
                                                <i class="fe fe-trash-2 fe-12"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        {{/images}}
                        {{^images}}
                        <div class="col-12">
                            <p class="text-muted text-center py-5">No images yet. Upload some above.</p>
                        </div>
                        {{/images}}
                    </div>

                </div>
            </div>
        </div>
    </main>
</div>

<!-- Lightbox -->
<div id="lightbox" class="lightbox-overlay">
    <span class="lightbox-close" id="lightboxClose">&times;</span>
    <span class="lightbox-counter" id="lightboxCounter"></span>
    <span class="lightbox-arrow prev" id="lightboxPrev">&#8249;</span>
    <img id="lightboxImg" class="lightbox-img" src="" alt="">
    <span class="lightbox-arrow next" id="lightboxNext">&#8250;</span>
    <div class="lightbox-actions">
        <button class="btn btn-sm btn-light" id="lightboxCopy"><i class="fe fe-copy fe-12 mr-1"></i>Copy URL</button>
        <a class="btn btn-sm btn-light" id="lightboxDownload" href="#" download><i class="fe fe-download fe-12 mr-1"></i>Download</a>
    </div>
</div>

{{> menu }}

<script src="/js/jquery.lazy.min.js"></script>
<script src="/js/jquery.lazy.plugins.min.js"></script>

<script>
$(document).ready(function () {

    $(".lazy").Lazy({ threshold: 200, removeAttribute: false });

    // ── Upload ─────────────────────────────────────────────────────────────

    var dropZone = document.getElementById('dropZone');

    dropZone.addEventListener('click', function () {
        document.getElementById('fileInput').click();
    });

    dropZone.addEventListener('dragover', function (e) {
        e.preventDefault();
        dropZone.classList.add('drag-over');
    });

    dropZone.addEventListener('dragleave', function () {
        dropZone.classList.remove('drag-over');
    });

    dropZone.addEventListener('drop', function (e) {
        e.preventDefault();
        dropZone.classList.remove('drag-over');
        uploadFiles(e.dataTransfer.files);
    });

    document.getElementById('fileInput').addEventListener('change', function () {
        uploadFiles(this.files);
    });

    function uploadFiles(files) {
        if (!files || files.length === 0) return;

        var total = files.length;
        var done = 0;

        $('#uploadProgress').show();
        $('#progressBar').css('width', '0%');
        $('#uploadStatus').text('Uploading 0/' + total + '...');

        Array.from(files).forEach(function (file) {
            var fd = new FormData();
            fd.append('file', file);

            $.ajax({
                url: '/images',
                type: 'POST',
                data: fd,
                processData: false,
                contentType: false,
                success: function (res) {
                    done++;
                    var pct = Math.round((done / total) * 100);
                    $('#progressBar').css('width', pct + '%');
                    $('#uploadStatus').text('Uploading ' + done + '/' + total + '...');
                    if (done === total) {
                        $('#uploadStatus').text('Done!');
                        setTimeout(function () { location.reload(); }, 600);
                    }
                },
                error: function () {
                    done++;
                    if (done === total) { location.reload(); }
                }
            });
        });
    }

    // ── Copy URL ───────────────────────────────────────────────────────────

    $(document).on('click', '.btnCopy', function () {
        var url = window.location.origin + '/img/' + $(this).data('filename');
        navigator.clipboard.writeText(url).then(function () {
            $.bootstrapPurr('URL copied to clipboard', { type: 'success', delay: 1500 });
        });
    });

    $('#lightboxCopy').on('click', function () {
        var url = $('#lightboxImg').attr('src');
        navigator.clipboard.writeText(window.location.origin + url).then(function () {
            $.bootstrapPurr('URL copied to clipboard', { type: 'success', delay: 1500 });
        });
    });

    // ───────────────────────────────────────────────────────────────

    $(document).on('click', '.btnDelete', function () {
        var filename = $(this).data('filename');
        var $item = $(this).closest('.gallery-item');

        if (!confirm('Delete ' + filename + '?')) return;

        var result = ajaxCall('DELETE', '/images/' + encodeURIComponent(filename), null, false, false);
        if (result !== false) {
            $item.fadeOut(200, function () { $(this).remove(); });
        }
    });

    // ── Lightbox ───────────────────────────────────────────────────────────

    var currentIndex = 0;

    function getImages() {
        return $('.gallery-item:visible .gallery-img');
    }

    function openLightbox(index) {
        var $imgs = getImages();
        if ($imgs.length === 0) return;
        currentIndex = (index + $imgs.length) % $imgs.length;
        var src = $imgs.eq(currentIndex).attr('data-src');
        $('#lightboxImg').attr('src', src);
        $('#lightboxDownload').attr('href', src);
        $('#lightboxCounter').text((currentIndex + 1) + ' / ' + $imgs.length);
        $('#lightbox').addClass('active');
    }

    $(document).on('click', '.gallery-img', function () {
        var index = getImages().index(this);
        openLightbox(index);
    });

    $('#lightboxPrev').on('click', function (e) {
        e.stopPropagation();
        openLightbox(currentIndex - 1);
    });

    $('#lightboxNext').on('click', function (e) {
        e.stopPropagation();
        openLightbox(currentIndex + 1);
    });

    $('#lightboxClose').on('click', function () {
        $('#lightbox').removeClass('active');
    });

    $('#lightbox').on('click', function (e) {
        if (e.target === this) {
            $('#lightbox').removeClass('active');
        }
    });

    $(document).on('keydown', function (e) {
        if (!$('#lightbox').hasClass('active')) return;
        if (e.key === 'Escape')       { $('#lightbox').removeClass('active'); }
        else if (e.key === 'ArrowLeft')  { openLightbox(currentIndex - 1); }
        else if (e.key === 'ArrowRight') { openLightbox(currentIndex + 1); }
    });

});
</script>
</body>
</html>